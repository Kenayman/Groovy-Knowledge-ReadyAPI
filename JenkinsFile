pipeline {
    agent any

    stages {

        stage('Create TXT file') {
            steps {
                writeFile file: 'demo.txt', text: 'Hello from Jenkins!'
            }
        }

        stage('Read TXT file') {
            steps {
                echo readFile('demo.txt')
            }
        }

        stage('Create Fake Allure Result') {
            steps {
                sh 'mkdir -p reports/allure-results'
                writeFile file: 'reports/allure-results/result.json', text: '{}'
            }
        }
    }

    post {
        always {
            allure includeProperties: false,
                   jdk: '',
                   resultPolicy: 'LEAVE_AS_IS',
                   results: [[path: 'reports/allure-results']]
        }
    }
}