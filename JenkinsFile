pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                bat 'whoami'
                bat 'mvn clean test'
            }
        }
    }

    post {
        always {
            allure(
                includeProperties: false,
                jdk: '',
                results: [[path: 'target/allure-results']]
            )
        }
    }
}