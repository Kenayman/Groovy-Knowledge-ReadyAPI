pipeline {
    agent any

    stages {
        stage('Generate Fake Test Results') {
            steps {
                bat '''
                mkdir target\\allure-results

                echo { ^
                  "uuid": "12345", ^
                  "name": "Pipeline Test Example", ^
                  "status": "passed", ^
                  "stage": "finished", ^
                  "steps": [], ^
                  "attachments": [], ^
                  "labels": [ ^
                    {"name":"suite","value":"Jenkins Pipeline"}, ^
                    {"name":"framework","value":"manual"} ^
                  ] ^
                } > target\\allure-results\\result.json
                '''
            }
        }
    }

    post {
        always {
            allure([
                includeProperties: false,
                jdk: '',
                results: [[path: 'target/allure-results']]
            ])
        }
    }
}