pipeline {
    agent any

    tools {
        maven "M3"
    }

    stages {
        stage('Test') {
            steps {
                bat 'mvn clean test'
            }
        }
    }

    post {
        success {
            allure([
                includeProperties: false,
                jdk: '',
                properties: [],
                reportBuildPolicy: 'ALWAYS',
                results: [[path: 'target/allure-results']]
            ])
        }
    }
}